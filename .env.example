# --- Capacitor (native iOS/Android) ---

# Production URL the native app loads at launch.
# This MUST point at the deployed web app (NextAuth, KV, push routes all live here).
# Example: https://lifttracker.vercel.app
CAP_SERVER_URL=

# Optional: override the bundle / package id used by the iOS and Android builds.
# Default: com.besaif.lifttracker
# CAP_APP_ID=com.besaif.lifttracker
